{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Win System Monitor",
  "version": "1.0.0",
  "identifier": "com.mofeng.win-system-monitor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Win System Monitor",
        "width": 200,
        "height": 120,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "skipTaskbar": true,
        "visible": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "Win System Monitor"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
